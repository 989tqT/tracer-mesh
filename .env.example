# Tracer Mesh Environment Configuration

# redis connection endpoint url
REDIS_URL=redis://localhost:6379

# local llm server base url
OLLAMA_URL=http://localhost:11434

# target model name for security reasoning analysis
LLM_MODEL=llama3

# target model name for vector embeddings calculation
EMBEDDING_MODEL=nomic-embed-text

# local sqlite cve database path
DB_PATH=data/cve_db/nvd_mirror.db

# local chromadb directory path
CHROMA_PATH=data/cve_db/chroma
